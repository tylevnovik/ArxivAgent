{
	"name": "arxiv-agent-desktop",
	"version": "0.4.0",
	"description": "ArxivAgent desktop shell built with Electron, React, Tailwind CSS, and Vite",
	"main": "src/electron/main.cjs",
	"scripts": {
		"typecheck": "tsc --noEmit",
		"build": "bun run typecheck && vite build",
		"prepare:backend-runtime": "node scripts/prepare-backend-runtime.cjs",
		"test:unit": "vitest run",
		"test:unit:watch": "vitest",
		"test:e2e": "playwright test",
		"test": "bun run test:unit",
		"start": "electron .",
		"smoke": "electron . --smoke-test",
		"smoke:packaged": "./build/electron/win-unpacked/ArxivAgent.exe --smoke-test",
		"dev": "concurrently \"bun run hmr\" \"electron .\"",
		"dev:hmr": "bun run dev",
		"hmr": "vite --port 5173",
		"pack": "bun run prepare:backend-runtime && bun run build && electron-builder --dir",
		"build:canary": "bun run prepare:backend-runtime && bun run build && electron-builder --win nsis"
	},
	"dependencies": {
		"@assistant-ui/react": "^0.14.18",
		"@assistant-ui/styles": "^0.3.7",
		"@emotion/react": "^11.14.0",
		"@emotion/styled": "^11.14.1",
		"@mui/icons-material": "^9.1.1",
		"@mui/material": "^9.1.1",
		"dompurify": "^3.4.10",
		"marked": "^18.0.5",
		"react": "^19",
		"react-dom": "^19"
	},
	"devDependencies": {
		"@playwright/test": "^1.60.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/bun": "latest",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@vitejs/plugin-react": "^4.3.4",
		"autoprefixer": "^10.4.20",
		"concurrently": "^9.1.0",
		"electron": "^42.4.0",
		"electron-builder": "^26.15.2",
		"jsdom": "^29.1.1",
		"postcss": "^8.4.49",
		"tailwindcss": "^3.4.16",
		"typescript": "^5.7.2",
		"vite": "^6.0.3",
		"vitest": "^4.1.8"
	},
	"build": {
		"appId": "dev.tylevnovik.arxivagent",
		"productName": "ArxivAgent",
		"directories": {
			"output": "build/electron"
		},
		"files": [
			"dist/**/*",
			"src/electron/**/*",
			"package.json"
		],
		"extraResources": [
			{
				"from": "../app.py",
				"to": "backend/app.py"
			},
			{
				"from": "../config.py",
				"to": "backend/config.py"
			},
			{
				"from": "../pyproject.toml",
				"to": "backend/pyproject.toml"
			},
			{
				"from": "../.python-version",
				"to": "backend/.python-version"
			},
			{
				"from": "../core",
				"to": "backend/core",
				"filter": [
					"**/*",
					"!**/__pycache__/**",
					"!**/*.pyc"
				]
			},
			{
				"from": "../prompts",
				"to": "backend/prompts",
				"filter": [
					"**/*"
				]
			},
			{
				"from": ".backend-runtime/python",
				"to": "python",
				"filter": [
					"**/*",
					"!**/__pycache__/**",
					"!**/*.pyc"
				]
			},
			{
				"from": ".backend-runtime/site-packages",
				"to": "python-site-packages",
				"filter": [
					"**/*",
					"!**/__pycache__/**",
					"!**/*.pyc"
				]
			}
		],
		"win": {
			"target": [
				"nsis"
			],
			"artifactName": "ArxivAgent-Setup-${version}.${ext}"
		},
		"nsis": {
			"oneClick": false,
			"perMachine": false,
			"allowToChangeInstallationDirectory": true
		}
	}
}
